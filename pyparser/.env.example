# --- Server ---
HOST=0.0.0.0
PORT=8800
SECURITY_ENABLED=false
CORS_ORIGINS=*

# --- Storage ---
SHARDS_DIR=./data/shards
BATCH_SIZE=1000

# --- Database (MySQL default) ---
DB_DIALECT=mysql            # mysql | mssql | none
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cf_parser
DB_USER=root
DB_PASSWORD=
